{
  "name": "quickx",
  "version": "0.2.0",
  "description": "Windows 桌面效率工具 - 快速搜索链接、笔记、代码片段、剪切板管理",
  "main": "dist/main/index.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "node scripts/dev-main.js",
    "dev:renderer": "vite",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "node scripts/build-main.js",
    "build:renderer": "vite build",
    "start": "electron .",
    "bs": "npm run build && npm run start",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win"
  },
  "keywords": [
    "electron",
    "react",
    "typescript",
    "desktop",
    "productivity"
  ],
  "dependencies": {
    "electron-updater": "^6.8.9",
    "highlight.js": "^11.9.0",
    "lucide-react": "^0.400.0",
    "marked": "^4.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "@tailwindcss/typography": "^0.5.20",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.0.0",
    "electron": "^32.3.3",
    "electron-builder": "^25.0.0",
    "esbuild": "^0.24.0",
    "jimp": "^0.22.12",
    "postcss": "^8.4.0",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  },
  "volta": {
    "node": "22.23.1"
  }
}
